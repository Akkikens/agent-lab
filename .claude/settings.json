{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cat | /Users/akshay/Documents/GitHub/agent-lab/hooks/safety-check.sh",
            "statusMessage": "Safety check..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "cat | /Users/akshay/Documents/GitHub/agent-lab/hooks/env-protection.sh",
            "statusMessage": "Secrets scan..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cat | /Users/akshay/Documents/GitHub/agent-lab/hooks/env-protection.sh",
            "statusMessage": "Secrets scan..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | /Users/akshay/Documents/GitHub/agent-lab/hooks/audit-log.sh",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | /Users/akshay/Documents/GitHub/agent-lab/hooks/compaction-saver.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat | /Users/akshay/Documents/GitHub/agent-lab/hooks/quality-gate.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Agent(*)",
      "mcp__task-tracker__*"
    ]
  }
}
